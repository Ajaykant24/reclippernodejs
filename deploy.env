# Reclipper Backend Deployment Configuration
# Used by docker-compose.yml to configure the Node.js API server

# Server Configuration
PORT=8000
NODE_ENV=production

# Storage Configuration
STORAGE_DIR=/var/data

# Admin Configuration
ADMIN_EMAILS=kantajay381@gmail.com

# CORS Configuration (allow Vercel frontend + local development)
CORS_ORIGINS=https://reclippernodejs.vercel.app,https://reclipper.vercel.app,https://www.reclipper.com,http://localhost:3000
