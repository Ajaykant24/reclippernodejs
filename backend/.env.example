# Copy this file to `.env` on the VPS and fill in real values. Never commit the real .env.
# Used by backend/docker-compose.yml (env_file: .env).

# Gemini API key (required for AI overlays + captions). Keep secret.
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model (default is fine).
GEMINI_MODEL=gemini-2.0-flash

# Where the backend writes data/, clips/, repurpose_outputs/.
# docker-compose mounts a named volume here, so leave as /var/data.
STORAGE_DIR=/var/data

# Allowed frontend origin(s) for CORS — must match the frontend URL exactly (scheme + host, no trailing slash).
# With a domain:
CORS_ORIGINS=https://yourdomain.com
ALLOW_ORIGINS=https://yourdomain.com
# No-domain fallback:
# CORS_ORIGINS=http://YOUR_VPS_IP
# ALLOW_ORIGINS=http://YOUR_VPS_IP

# Port the server listens on (docker-compose maps 8000:8000).
PORT=8000
