# Copy this file to `.env.production` and set your real backend URL before running `npm run build`.
# This is baked into the build at compile time (Vite reads import.meta.env.VITE_API_URL).
#
# With a domain (recommended):
VITE_API_URL=https://api.yourdomain.com
#
# No-domain fallback (raw VPS IP + backend port):
# VITE_API_URL=http://YOUR_VPS_IP:8000
