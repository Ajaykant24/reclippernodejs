# Copy this file to deploy.env and fill in real values, then run:
#   docker compose --env-file deploy.env up -d --build

# The subdomain that points to this server's public IP (create a DNS A record).
# Caddy gets an HTTPS cert for exactly this domain.
API_DOMAIN=api.clippar.online

# Your Google Gemini API key (required for overlays + captions).
GEMINI_API_KEY=your_gemini_key_here

# Gemini model (leave as-is unless you have a reason to change it).
GEMINI_MODEL=gemini-2.0-flash

# Where your frontend is served from, so the API accepts its requests.
# Comma-separated. Include both your Vercel URL and your custom domain.
CORS_ORIGINS=https://reclippernodejs.vercel.app,https://clippar.online
