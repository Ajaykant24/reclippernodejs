# Reclipper Backend Deployment Configuration Template
# Copy this file to deploy.env and update values for your environment
# Used by docker-compose.yml to configure the Node.js API server

# Server Configuration
PORT=8000
NODE_ENV=production

# Storage Configuration (persistent volume mount point)
STORAGE_DIR=/var/data

# Admin Configuration (comma-separated emails allowed as admins)
ADMIN_EMAILS=kantajay381@gmail.com

# CORS Configuration (comma-separated list of allowed origins)
# Update with your frontend URLs and any additional origins
CORS_ORIGINS=https://reclipper.vercel.app,https://www.reclipper.com,http://localhost:3000
