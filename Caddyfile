# Caddy automatically obtains and renews a free Let's Encrypt HTTPS
# certificate for your domain, then forwards traffic to the API container.
# The domain comes from the API_DOMAIN value in deploy.env.

{$API_DOMAIN} {
	reverse_proxy api:8000

	# Allow large video uploads (matches the backend's 500MB limit).
	request_body {
		max_size 500MB
	}
}
